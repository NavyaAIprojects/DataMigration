# ============================================================================
# MSSQL TO DATABRICKS — MIGRATION DECISIONS (.env)
# ============================================================================
# Pre-configured answers for all 14 human-decision issues.
# Feed this file to the Claude Code migration agent before running.
# With these decisions, the agent auto-fixes 58/66 issues (zero human pauses).
#
# Project:  HealthDB POC
# Source:   GCP Cloud SQL (SQL Server 2019 Standard)
# Target:   Databricks Delta Lake (Unity Catalog)
# Database: HealthcarePOC (30 tables, 3 schemas, 288,289 rows)
# Date:     March 2026
# ============================================================================

# -----------------------------------------------------------------------
# ISSUE #7 — HIERARCHYID
# Status: NOT APPLICABLE — No HIERARCHYID columns found in schema
# Verified: All 30 tables use standard INT foreign keys
# -----------------------------------------------------------------------
MIGRATION_HIERARCHYID_ACTION=not_applicable
MIGRATION_HIERARCHYID_TABLES=none

# -----------------------------------------------------------------------
# ISSUE #9 — GEOGRAPHY / GEOMETRY
# Status: NOT APPLICABLE — No spatial columns found in schema
# Verified: Facility locations not stored as spatial types
# -----------------------------------------------------------------------
MIGRATION_SPATIAL_ACTION=not_applicable
MIGRATION_SPATIAL_TABLES=none

# -----------------------------------------------------------------------
# ISSUE #28 — STORED PROCEDURES
# Decision: Convert all 4 procs to Databricks SQL Scripting
# Reason: Closest syntax to T-SQL, minimal rewrite effort
# -----------------------------------------------------------------------
MIGRATION_STORED_PROC_ACTION=sql_scripting
MIGRATION_STORED_PROC_MAP_1=clinical.usp_get_patient_summary:sql_scripting
MIGRATION_STORED_PROC_MAP_2=billing.usp_post_payment:sql_scripting
MIGRATION_STORED_PROC_MAP_3=billing.usp_ar_aging_report:sql_scripting
MIGRATION_STORED_PROC_MAP_4=pharmacy.usp_dispense_medication:sql_scripting

# -----------------------------------------------------------------------
# ISSUE #29 — TRIGGERS
# Decision: Move trigger logic to DLT Expectations
# Reason: Healthcare data quality checks are best handled inline
#         during data processing. DLT Expectations can DROP, FAIL,
#         or FLAG bad rows automatically.
# -----------------------------------------------------------------------
MIGRATION_TRIGGER_ACTION=dlt_expectations
MIGRATION_TRIGGER_VIOLATION_MODE=flag
# Options for violation mode: drop_row | fail_pipeline | flag

# -----------------------------------------------------------------------
# ISSUE #31 — TRANSACTIONS (BEGIN/COMMIT/ROLLBACK)
# Decision: Use Delta ACID — remove explicit transaction code
# Reason: Delta Lake provides automatic ACID guarantees per operation.
#         Multi-table atomicity handled via Databricks Workflows.
# -----------------------------------------------------------------------
MIGRATION_TRANSACTION_ACTION=delta_acid
MIGRATION_TRANSACTION_REMOVE_EXPLICIT=true
MIGRATION_TRANSACTION_MULTI_TABLE=databricks_workflows

# -----------------------------------------------------------------------
# ISSUE #34 — CURSOR LOGIC
# Decision: Rewrite as set-based SQL with window functions
# Reason: Set-based is idiomatic Spark SQL, better performance,
#         uses ROW_NUMBER/LAG/LEAD where sequencing is needed.
#         Fallback to Python UDF only if set-based is impossible.
# -----------------------------------------------------------------------
MIGRATION_CURSOR_ACTION=set_based_rewrite
MIGRATION_CURSOR_WINDOW_FUNCTIONS=ROW_NUMBER,LAG,LEAD,RANK,DENSE_RANK
MIGRATION_CURSOR_FALLBACK=python_udf

# -----------------------------------------------------------------------
# ISSUE #35 — TRY...CATCH ERROR HANDLING
# Decision: Python try/except wrappers + error audit table
# Reason: Most flexible approach. Errors logged to Delta table
#         for monitoring. Retry Agent can consume error logs.
# -----------------------------------------------------------------------
MIGRATION_ERROR_HANDLING_ACTION=python_wrapper
MIGRATION_ERROR_AUDIT_TABLE=healthcare_poc.audit.migration_errors
MIGRATION_ERROR_NOTIFY_ON_FAILURE=true
MIGRATION_ERROR_MAX_RETRIES=3

# -----------------------------------------------------------------------
# ISSUE #41 — COLLATION / CASE SENSITIVITY
# Decision: Apply UTF8_LCASE on key lookup/join/filter columns only
# Reason: Balanced approach — preserves case-insensitive behavior
#         from SQL Server on columns that matter, without slowing
#         down all string operations.
# -----------------------------------------------------------------------
MIGRATION_COLLATION_ACTION=utf8_lcase_selective
MIGRATION_COLLATION_APPLY_TO=patient_name,first_name,last_name,provider_name,full_name,payer_name,payer_code,claim_status,icd10_code,cpt_code,brand_name,generic_name,ndc_code,facility_name,facility_code,npi,mrn,claim_number,rx_number,invoice_number,auth_number,allergen_class
# Rule: Apply UTF8_LCASE to any column used in WHERE, JOIN, GROUP BY,
#       or DISTINCT that was case-insensitive in SQL Server.
#       Agent should also scan views and stored procs for additional columns.

# -----------------------------------------------------------------------
# ISSUE #42 — TRAILING SPACES
# Decision: RTRIM all CHAR/VARCHAR columns during export
# Reason: Clean at source — ensures no trailing spaces ever
#         reach Databricks. Eliminates comparison discrepancies.
# -----------------------------------------------------------------------
MIGRATION_TRAILING_SPACE_ACTION=rtrim_on_export
MIGRATION_TRAILING_SPACE_APPLY_TO=all_char_varchar
# Applied during pymssql CSV export phase (GCS Export Agent)

# -----------------------------------------------------------------------
# ISSUE #51 — SSIS PACKAGES
# Status: NOT APPLICABLE — No SSIS packages in HealthDB POC
# Verified: ETL handled entirely by 8-agent pipeline
# -----------------------------------------------------------------------
MIGRATION_SSIS_ACTION=not_applicable

# -----------------------------------------------------------------------
# ISSUE #52 — SQL AGENT JOBS
# Status: NOT APPLICABLE — No SQL Agent Jobs in HealthDB POC
# Verified: No scheduled jobs found in deployment report
# -----------------------------------------------------------------------
MIGRATION_SQL_AGENT_ACTION=not_applicable

# -----------------------------------------------------------------------
# ISSUE #53 — CLR STORED PROCEDURES
# Status: NOT APPLICABLE — No CLR procs in HealthDB POC
# Verified: All 4 stored procedures are pure T-SQL
# -----------------------------------------------------------------------
MIGRATION_CLR_ACTION=not_applicable

# -----------------------------------------------------------------------
# ISSUE #57 — INDEX STRATEGY (B-tree replacement)
# Decision: Z-ORDER + OPTIMIZE on high-cardinality filter columns
# Reason: Best general-purpose approach for query performance
#         on Delta Lake without needing liquid clustering setup.
# -----------------------------------------------------------------------
MIGRATION_INDEX_ACTION=zorder_optimize
MIGRATION_INDEX_OPTIMIZE_clinical_patients=patient_id,mrn
MIGRATION_INDEX_OPTIMIZE_clinical_appointments=patient_id,appointment_date
MIGRATION_INDEX_OPTIMIZE_clinical_vital_signs=patient_id
MIGRATION_INDEX_OPTIMIZE_clinical_lab_orders=patient_id,test_code
MIGRATION_INDEX_OPTIMIZE_billing_claims=claim_number,patient_id
MIGRATION_INDEX_OPTIMIZE_billing_payments=claim_id,payment_date
MIGRATION_INDEX_OPTIMIZE_billing_invoices=invoice_number
MIGRATION_INDEX_OPTIMIZE_billing_prior_authorizations=auth_number
MIGRATION_INDEX_OPTIMIZE_pharmacy_prescriptions=patient_id,rx_number
MIGRATION_INDEX_OPTIMIZE_pharmacy_dispenses=prescription_id
MIGRATION_INDEX_OPTIMIZE_pharmacy_formulary=payer_id,drug_id
MIGRATION_INDEX_OPTIMIZE_pharmacy_inventory=facility_id,drug_id
# Agent should run OPTIMIZE ZORDER BY after initial data load

# -----------------------------------------------------------------------
# ISSUE #66 — DECIMAL SEPARATOR LOCALE
# Decision: Period (.) as decimal separator — US standard
# Reason: GCP Cloud SQL in us-central1, US locale confirmed
# -----------------------------------------------------------------------
MIGRATION_DECIMAL_SEPARATOR=period
MIGRATION_DECIMAL_FORMAT=standard_us

# ============================================================================
# SUMMARY
# ============================================================================
# Not Applicable:  5 decisions  (#7, #9, #51, #52, #53)
# Auto-defaults:   6 decisions  (#31, #34, #35, #41, #42, #66)
# User chosen:     2 decisions  (#28, #29)
# Schema verified: 1 decision   (#57)
#
# With this file: 58 of 66 issues are auto-fixed (88%)
# Remaining 8 are platform limits with workarounds (see PDF Section I)
# ============================================================================

