# USAGE
# ============================================================================
# Option 1: Source this file before running migration
#   source migration_decisions.env && python main.py
#
# Option 2: Pass as argument
#   python main.py --decisions migration_decisions.env
#
# Option 3: Place in project root alongside .env
#   cp migration_decisions.env ~/Downloads/mssql-to-databricks-migration/
#   # Agent auto-detects and reads it
